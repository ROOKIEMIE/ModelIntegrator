# 以 docker-compose.yml 所在目录为根目录
MCP_PROJECT_DIR=.

# 对外网关端口（默认 59081）
MCP_EXTERNAL_PORT=59081

# 控制平面服务配置
MCP_CONFIG=/opt/modelintegrator/resources/config/config.example.yaml
MCP_SERVER_ADDRESS=:8080
MCP_LOG_LEVEL=info
MCP_LOG_FORMAT=text

# SQLite 路径（默认放在 resources/config）
MCP_SQLITE_PATH=/opt/modelintegrator/resources/config/modelintegrator.db

# 模型目录（宿主机 -> 容器）
MCP_MODEL_DIR_HOST=./resources/models
MCP_MODEL_ROOT_DIR=/opt/modelintegrator/models

# 可按需覆盖 integration endpoint
MCP_LMSTUDIO_ENDPOINT=http://192.168.50.241:1234
MCP_LMSTUDIO_CACHE_ENABLED=true
MCP_LMSTUDIO_CACHE_REFRESH_SECONDS=30
MCP_DOCKER_ENDPOINT=unix:///var/run/docker.sock
# 非 root 运行时用于访问 docker.sock（建议与宿主机 /var/run/docker.sock 的 gid 保持一致）
MCP_DOCKER_GID=998
MCP_PORTAINER_ENDPOINT=http://portainer:9000
MCP_GPU_PROBE_IMAGE=nvidia/cuda:12.4.1-base-ubuntu22.04

# download profile 可选参数
MCP_HF_CACHE_DIR=/data/hf-cache
MCP_ARIA2_RPC_SECRET=change-me
MCP_ARIA2_RPC_PORT=6800
MCP_ARIA2_LISTEN_PORT=6888

# vllm profile 可选参数（NVIDIA GPU）
MCP_VLLM_EXTERNAL_PORT=58000
MCP_VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
MCP_VLLM_SERVED_MODEL_NAME=qwen2.5-7b-instruct
MCP_VLLM_GPU_MEMORY_UTILIZATION=0.90
MCP_VLLM_MAX_MODEL_LEN=8192
# 可选：访问私有或 gated 模型时使用
HUGGING_FACE_HUB_TOKEN=

# 网关时区
TZ=UTC

# 附加组件按需启用：
# docker compose --profile addons up -d --build
# 下载容器按需启用：
# docker compose --profile download up -d
# vLLM 运行模板按需启用：
# docker compose --profile vllm up -d
